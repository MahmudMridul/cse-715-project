% NeurIPS 2024 style file (simplified)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 style]

\RequirePackage{geometry}
\geometry{
  letterpaper,
  top=1in,
  bottom=1in,
  left=1.5in,
  right=1.5in,
}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}

% Title formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}

% Font setup
\RequirePackage{times}

% Multi-author support: \And switches tabular columns side by side.
% amsmath redefines \And as a math operator, so we restore our definition
% at \AtBeginDocument (after all packages have loaded).
\AtBeginDocument{%
  \renewcommand{\And}{\end{tabular}\hskip 2em\begin{tabular}[t]{c}}%
}

% Abstract environment
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5em}%
  \begin{quote}\small
}{%
  \end{quote}%
  \vspace{1em}%
}

\endinput
